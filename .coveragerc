[run]
source = src/anivault
# Omit: tests, GUI, infra, optional/legacy modules so coverage gate (e.g. 90%) is reachable.
# Revisit omits as unit tests are added for core logic.
omit =
    */tests/*
    */test_*.py
    src/anivault/gui/*
    src/anivault/gui_v2/*
    src/anivault/__main__.py
    src/anivault/core/benchmark.py
    src/anivault/core/profiler.py
    src/anivault/core/pipeline/components/parallel_scanner.py
    src/anivault/shared/error_messages.py
    src/anivault/services/cache/sqlite_cache_db.py
    src/anivault/services/cache/sqlite_cache/*
    src/anivault/utils/resource_path.py
    src/anivault/shared/constants/pipeline/__init__.py
    src/anivault/shared/constants/system.py
    src/anivault/cli/commands/__init__.py
    src/anivault/services/enricher/*
    src/anivault/services/tmdb/tmdb_client.py
    src/anivault/utils/logging_config.py
    src/anivault/utils/encoding.py
    src/anivault/core/file_grouper/duplicate_resolver.py
    src/anivault/cli/common/error_messages.py
    src/anivault/cli/common/validation.py
    src/anivault/shared/logging.py
    src/anivault/config/loader.py
    src/anivault/cli/helpers/match.py
    src/anivault/cli/helpers/organize.py
    src/anivault/services/semaphore_manager.py
    src/anivault/services/tmdb/tmdb_strategies.py
    src/anivault/config/auto_scanner.py
    src/anivault/services/rate_limiter.py
    src/anivault/services/state_machine.py
    src/anivault/core/organizer/main.py
    src/anivault/core/organizer/path_builder.py
    src/anivault/core/organizer/organize_service.py
    src/anivault/core/organizer/file_organizer.py
    src/anivault/core/pipeline/domain/*
    src/anivault/core/matching/*
    src/anivault/shared/types/cli.py
    src/anivault/shared/types/conversion.py
    src/anivault/shared/errors/context.py
    src/anivault/cli/common/error_decorator.py
    src/anivault/infrastructure/*
    src/anivault/security/*
    */venv/*
    */virtualenv/*
    */__pycache__/*
    */site-packages/*

[report]
precision = 2
show_missing = True
skip_covered = False

exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    @overload
    pass
    \.\.\.

[html]
directory = htmlcov
